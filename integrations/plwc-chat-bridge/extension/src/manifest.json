{
  "manifest_version": 3,
  "name": "PLwC Chat Bridge",
  "short_name": "PLwC Bridge",
  "version": "0.2.0",
  "version_name": "0.2.0-rc19.dev2",
  "description": "Local PLwC gateway bridge for ChatGPT.",
  "icons": {
    "16": "icons/plwc-icon-512.png",
    "32": "icons/plwc-icon-512.png",
    "48": "icons/plwc-icon-512.png",
    "128": "icons/plwc-icon-512.png"
  },
  "action": {
    "default_title": "PLwC Chat Bridge",
    "default_icon": {
      "16": "icons/plwc-icon-512.png",
      "32": "icons/plwc-icon-512.png",
      "48": "icons/plwc-icon-512.png",
      "128": "icons/plwc-icon-512.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["ws://127.0.0.1:3007/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/plwc-icon-512.png"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ]
}
